{
  "name": "dinosaur",
  "version": "0.0.2",
  "displayName": "Dinosaur",
  "description": "Theme for VS Code with nice colors and contrast",
  "publisher": "JonasFernandes",
  "license": "MIT",
  "scripts": {
    "build": "node ./scripts/build.js",
    "package": "vsce package -o ./bin/dinosaur.vsix",
    "vsce:prepublish": "npm run build",
    "vsce:publish": "vsce publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jonasfernandes/dinosaur-theme.git"
  },
  "bugs": {
    "url": "https://github.com/jonasfernandes/dinosaur-theme/issues"
  },
  "engines": {
    "vscode": "^1.76.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "dinosaur",
    "dark",
    "theme",
    "dark-theme",
    "color-theme",
    "contrast",
    "pastel"
  ],
  "icon": "images/dino.png",
  "galleryBanner": {
    "color": "#424450",
    "theme": "dark"
  },
  "contributes": {
    "themes": [
      {
        "label": "Dinosaur Theme",
        "uiTheme": "vs-dark",
        "path": "./theme/dinosaur.json"
      },
      {
        "label": "Dinosaur Theme Soft",
        "uiTheme": "vs-dark",
        "path": "./theme/dinosaur-soft.json"
      }
    ]
  },
  "devDependencies": {
    "js-yaml": "^4.1.1",
    "prettier": "^3.0.0",
    "tinycolor2": "^1.6.0",
    "vsce": "^2.15.0"
  }
}
